# =============================================================================
# OpsRAG - Environment Variables
# =============================================================================
# Copy this file to .env and replace every placeholder with a real value:
#   cp .env.example .env
#
# All values below are PLACEHOLDERS - replace them. Secrets are read only from
# env vars / secret refs; never commit real secrets to the repo.
#
# MINIMUM to boot the quickstart: ANTHROPIC_API_KEY. Everything else has a
# safe default or is only needed when you enable the matching feature/config.
# Anything that varies per deployment (URLs, service names, ticket prefixes,
# clusters) is supplied via config/env - never hardcoded.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM providers
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME           # Anthropic API key (default LLM provider; required for quickstart)
OPENAI_API_KEY=sk-REPLACE_ME                  # OpenAI API key (used when llm.provider=openai)
# Vertex AI / Bedrock providers use ambient cloud credentials (ADC / AWS chain), see below.


# -----------------------------------------------------------------------------
# Model / provider selection (override WITHOUT editing YAML or rebuilding)
# -----------------------------------------------------------------------------
# Precedence: env var > config.yaml slot > cloud-bundle default.
# Pick a cloud bundle (sane per-purpose defaults), then override any model id
# below -- e.g. opt into Opus for max quality, or bump a deprecated model.
# Leave blank to use the config.yaml / bundle defaults.
OPSRAG_CLOUD_PROVIDER=                          # aws | gcp -- selects the per-purpose model bundle
OPSRAG_LLM_PROVIDER=                            # anthropic|openai|vertex|bedrock|ollama|litellm (default LLM slot)
OPSRAG_LLM_MODEL=                               # default/answer model id (e.g. us.anthropic.claude-sonnet-4-6)
OPSRAG_PRO_MODEL=                               # reasoning/escalation model (e.g. us.anthropic.claude-opus-4-8 for max quality)
OPSRAG_EMBEDDING_PROVIDER=                      # openai|vertex|bedrock|fastembed|cohere|ollama (indexing embedder)
OPSRAG_EMBEDDING_MODEL=                         # embedding model id (e.g. us.cohere.embed-v4:0)
OPSRAG_EMBEDDING_DIMENSION=                     # int; MUST match the model + the Qdrant collection dim (e.g. 1536)
OPSRAG_RERANKER_PROVIDER=                       # cohere|bedrock|vertex|fastembed|noop
OPSRAG_RERANKER_MODEL=                          # reranker model id (e.g. cohere.rerank-v3-5:0)
OPSRAG_VISION_ENABLED=                          # true|false -- image understanding (default true)
OPSRAG_VISION_PROVIDER=                         # anthropic|openai|vertex|bedrock|litellm (defaults to llm provider)
OPSRAG_VISION_MODEL=                            # vision fallback model id; blank = provider-aware default
                                                #   (Bedrock/Anthropic: claude-sonnet-4-6; Vertex: gemini-3-flash-preview)
# Note: changing the embedding model/dimension requires a re-index into a fresh
# collection (vectors of different dims are not comparable).


# -----------------------------------------------------------------------------
# Embeddings
# -----------------------------------------------------------------------------
# OPENAI_API_KEY (above) is reused when embedding.provider=openai.
# Vertex / Bedrock / FastEmbed embedding providers need no key here:
#   - fastembed: runs locally, downloads an ONNX model on first use, no key
#   - vertex/bedrock: use ambient cloud credentials (see Cloud credentials)
COHERE_API_KEY=CHANGE_ME                      # Cohere API key (reranker.provider=cohere; falls back to no-op reranker if empty)


# -----------------------------------------------------------------------------
# Vector store
# -----------------------------------------------------------------------------
QDRANT_URL=http://your-qdrant.example.com:6333   # Qdrant endpoint (vector_store.provider=qdrant)
PGVECTOR_DSN=postgresql://USER:CHANGE_ME@your-db.example.com:5432/opsrag   # DSN for pgvector vector store (vector_store.provider=pgvector)


# -----------------------------------------------------------------------------
# Sessions / Memory / Postgres
# -----------------------------------------------------------------------------
POSTGRES_DSN=postgresql://USER:CHANGE_ME@your-db.example.com:5432/opsrag   # Postgres DSN for session + memory persistence
OPSRAG_POSTGRES_DSN=                          # Optional DSN override used by the DB migrator (falls back to POSTGRES_DSN)
OPSRAG_AUTO_MIGRATE=true                      # Run schema migrations on startup (true/false)


# -----------------------------------------------------------------------------
# Knowledge graph (optional; knowledge_graph.provider=neo4j)
# -----------------------------------------------------------------------------
NEO4J_PASSWORD=CHANGE_ME                       # Password for the OpsRAG Neo4j instance


# -----------------------------------------------------------------------------
# Auth / OIDC (optional; only when auth block is configured)
# -----------------------------------------------------------------------------
# OIDC issuer and audience are supplied via the `auth:` block in config.yaml,
# not via env. No OIDC secret is read directly from env by the backend.


# -----------------------------------------------------------------------------
# API security (optional)
# -----------------------------------------------------------------------------
OPSRAG_API_KEYS=                              # Comma-separated API keys accepted by the API; empty = auth disabled (dev only)


# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------
PHOENIX_API_KEY=CHANGE_ME                     # Phoenix (Arize) API key for trace export; empty = local/no-auth collector
PHOENIX_COLLECTOR_ENDPOINT=http://your-phoenix.example.com:6006   # Phoenix OTLP collector endpoint
OTEL_EXPORTER_OTLP_HEADERS=                   # Extra OTLP exporter headers (set automatically from PHOENIX_API_KEY if empty)


# -----------------------------------------------------------------------------
# Branding (optional; white-label overrides surfaced to the UI)
# -----------------------------------------------------------------------------
OPSRAG_BRAND_NAME=OpsRAG                       # Product name shown in the UI
OPSRAG_BRAND_SUBTITLE=DevOps Intelligence      # Subtitle shown under the product name
OPSRAG_BRAND_ASSISTANT_NAME=OpsRAG             # Assistant display name in chat
OPSRAG_BRAND_FAVICON_URL=                      # Absolute URL or path to a favicon; empty = generic icon
OPSRAG_BRAND_ACCENT_COLOR=                     # Hex accent color override (e.g. #6384ff); empty = UI default


# -----------------------------------------------------------------------------
# Source link base URLs (optional; render clickable links in answers)
# -----------------------------------------------------------------------------
OPSRAG_CONFLUENCE_BASE_URL=https://your-org.example.com/wiki   # Confluence site base URL for source links
OPSRAG_SLACK_WORKSPACE_URL=https://your-workspace.example.com  # Slack workspace web URL for source links
OPSRAG_ROOTLY_WEB_URL=https://your-rootly.example.com          # Rootly web UI base URL for incident links
OPSRAG_SCM_BASE_URL=https://your-scm.example.com               # SCM (GitLab/GitHub) base URL for code links


# -----------------------------------------------------------------------------
# Cloud credentials (optional; only for Vertex / Bedrock / GCP-backed features)
# -----------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json   # Path to GCP service-account JSON (ADC)
GOOGLE_CLOUD_PROJECT=your-gcp-project          # GCP project id (Vertex AI, CloudSQL)
CLOUD_ML_REGION=us-central1                    # Vertex AI region
OPSRAG_GCP_PROJECT=your-gcp-project            # GCP project override for the CloudSQL MCP
AWS_DEFAULT_REGION=us-east-1                   # AWS region (Bedrock LLM / embeddings)
AWS_PROFILE=your-aws-profile                   # AWS named profile (Bedrock credential chain)


# -----------------------------------------------------------------------------
# MCP integrations (only needed when the matching mcp.<name>.enabled: true)
# -----------------------------------------------------------------------------
# Each integration is off by default. Set these only when you enable the
# corresponding mcp.<name> block in config.yaml.
CLOUDFLARE_API_TOKEN=CHANGE_ME                 # mcp.cloudflare: Cloudflare API token (zones, DNS, Zero-Trust)
CLOUDFLARE_API_KEY=CHANGE_ME                   # mcp.cloudflare: Cloudflare API token (legacy var name read by the client)
CLOUDFLARE_API_KEY_FILE=/path/to/cloudflare-token   # mcp.cloudflare: file path holding the Cloudflare token (alternative to inline)
DD_API_KEY=CHANGE_ME                           # mcp.datadog: Datadog API key
DD_APP_KEY=CHANGE_ME                           # mcp.datadog: Datadog application key
DD_SITE=datadoghq.com                          # mcp.datadog: Datadog site (e.g. datadoghq.com, datadoghq.eu)
GITLAB_TOKEN=CHANGE_ME                         # mcp.gitlab + SCM indexing: GitLab token (read_api + read_repository). GITLAB_API_URL for self-hosted.
GITHUB_TOKEN=CHANGE_ME                         # mcp.github + SCM indexing: GitHub token (read-only fine-grained PAT). GITHUB_API_URL for GHES.
SENTRY_TOKEN=CHANGE_ME                         # mcp.sentry: Sentry auth token (org:read project:read team:read event:read). SENTRY_HOST + SENTRY_ORG.
GRAFANA_URL=https://grafana.example.com        # mcp.grafana: Grafana base URL
GRAFANA_TOKEN=CHANGE_ME                         # mcp.grafana: read-only service-account token
LOKI_URL=http://loki.example.com:3100          # mcp.loki: Grafana Loki base URL (LOKI_ORG_ID for multi-tenant)
SPLUNK_URL=https://splunk.example.com:8089     # mcp.splunk: Splunk mgmt API base URL
SPLUNK_TOKEN=CHANGE_ME                         # mcp.splunk: Splunk bearer token (search-capable role)
AWS_PROFILE=default                            # mcp.aws: AWS profile (or use AWS_ACCESS_KEY_ID/SECRET or IRSA); recommend ReadOnlyAccess
AWS_REGION=us-east-1                            # mcp.aws: default AWS region
GOOGLE_CLOUD_PROJECT=your-gcp-project          # mcp.gcp: default GCP project (auth via ADC / Workload Identity; *.viewer roles)
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000   # mcp.azure: default subscription (auth via DefaultAzureCredential; Reader role)
KUBECONFIG=/path/to/kubeconfig                 # mcp.kubernetes / prometheus: kubeconfig path (or in-cluster)
ROOTLY_API_TOKEN=CHANGE_ME                     # mcp.rootly + Rootly source: Rootly API token
SLACK_BOT_TOKEN=xoxb-REPLACE_ME                # mcp.slack + Slack source: Slack bot token (channels:history/read, users:read)
CONFLUENCE_EMAIL=service-account@example.com   # Confluence source: Atlassian account email
CONFLUENCE_API_TOKEN=CHANGE_ME                 # Confluence source: Atlassian API token
ES_URL=https://elasticsearch.example.com:9200  # mcp.elasticsearch: Elasticsearch/OpenSearch URL
ES_API_KEY=CHANGE_ME                           # mcp.elasticsearch: base64 ES API key (or ES_USERNAME/ES_PASSWORD)
